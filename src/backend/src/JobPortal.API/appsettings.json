{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=JobPortal;Username=postgres;Password=your_password;",
    "Redis": ""
  },
  "Jwt": {
    "Issuer": "http://localhost:5000",
    "Audience": "http://localhost",
    "PublicKey": "REPLACE_WITH_RSA_PUBLIC_KEY_PEM",
    "PrivateKey": "REPLACE_WITH_RSA_PRIVATE_KEY_PEM"
  },
  "Security": {
    "PasswordPepper": "REPLACE_WITH_RANDOM_SECRET_PEPPER"
  },
  "FrontendUrl": "http://localhost:3000",
  "Email": {
    "SenderName": "JobPortal",
    "SenderAddress": "noreply@jobportal.com",
    "SmtpHost": "localhost",
    "SmtpPort": "1025",
    "SmtpUser": "",
    "SmtpPassword": ""
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost", "http://localhost:3000", "http://localhost:5173" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}

# ============================================================
# JobPortal — Environment Variables
# Copy this file to .env and fill in all values marked REQUIRED
# NEVER commit .env to version control
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=jobportal
POSTGRES_USER=jpuser
POSTGRES_PASSWORD=REQUIRED_change_me_strong_password   # REQUIRED

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=REQUIRED_change_me_redis_password        # REQUIRED

# ── JWT (RS256) ───────────────────────────────────────────────
# Generate a key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the PEM content below (replace newlines with \n)
JWT_ISSUER=https://api.jobportal.com
JWT_AUDIENCE=https://app.jobportal.com
JWT_PUBLIC_KEY=REQUIRED_RSA_PUBLIC_KEY_PEM              # REQUIRED
JWT_PRIVATE_KEY=REQUIRED_RSA_PRIVATE_KEY_PEM            # REQUIRED

# ── Argon2id Pepper ───────────────────────────────────────────
# Generate: openssl rand -hex 32
PASSWORD_PEPPER=REQUIRED_change_me_random_hex_secret    # REQUIRED

# ── SMTP (leave defaults to use MailHog in dev) ───────────────
EMAIL_SENDER_NAME=JobPortal
EMAIL_SENDER_ADDRESS=noreply@jobportal.com
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost
